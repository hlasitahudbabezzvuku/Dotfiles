[core]
	editor = nvim
	excludesfile = ~/.gitglobalignore

[status]
	submoduleSummary = true

[init]
	defaultBranch = development

[commit]
	gpgsign = true

[tag]
	gpgSign = true

[gpg]
	format = ssh

[pull]
	rebase = true

[fetch]
	prune = true
	all = true

[push]
	recurseSubmodules = on-demand
	autoSetupRemote = true

[rebase]
	autoStash = true

[merge]
	conflictStyle = zdiff3

[branch]
	sort = -committerdate

[submodule]
	recurse = true

[alias]
	lg = log --graph --all
